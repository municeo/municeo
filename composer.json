{
    "name": "municeo/municeo",
    "description": "Civic participation platform — report local issues to your municipality",
    "type": "project",
    "license": "AGPL-3.0-only",
    "require": {
        "php": ">=8.5",
        "ext-apcu": "*",
        "ext-gd": "*",
        "ext-intl": "*",
        "ext-pdo_pgsql": "*",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.2",
        "jsor/doctrine-postgis": "^2.4",
        "runtime/frankenphp-symfony": "^0.2",
        "symfony/asset": "^8.0",
        "symfony/asset-mapper": "^8.0",
        "symfony/console": "^8.0",
        "symfony/doctrine-bridge": "^8.0",
        "symfony/flex": "^2",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/mercure-bundle": "^0.3",
        "symfony/messenger": "^8.0",
        "symfony/password-hasher": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/scheduler": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/uid": "^8.0",
        "symfony/ux-stimulus-bundle": "^2.20",
        "symfony/ux-turbo": "^2.20",
        "symfony/validator": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.0",
        "symfony/browser-kit": "^8.0",
        "symfony/css-selector": "^8.0",
        "symfony/debug-bundle": "^8.0",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/web-profiler-bundle": "^8.0",
        "vincentlanglet/twig-cs-fixer": "^3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php bin/phpunit",
        "test:domain": "php bin/phpunit --testsuite Domain",
        "test:application": "php bin/phpunit --testsuite Application",
        "test:infrastructure": "php bin/phpunit --testsuite Infrastructure",
        "stan": "vendor/bin/phpstan analyse",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "rector": "vendor/bin/rector process",
        "rector-check": "vendor/bin/rector process --dry-run",
        "twig-lint": "vendor/bin/twig-cs-fixer lint templates/",
        "check": [
            "@cs-check",
            "@stan",
            "@rector-check",
            "@twig-lint",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.0"
        }
    }
}
